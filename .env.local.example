# Supabase — get these from your project dashboard at app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — for transactional emails (resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@insidestlcacademy.com
# Where admin notifications (new enrolments, new submissions) are sent
ADMIN_NOTIFICATION_EMAIL=david.oxley@insidestlc.com

# Stripe — payment integration (stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx

# Optional — pre-created Stripe Price IDs (recommended for production).
# If unset, Checkout creates inline prices from src/lib/courses.ts.
STRIPE_PRICE_90_DAY=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_AI_QA=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_QA_INTERVIEW=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PLAYWRIGHT=price_xxxxxxxxxxxxxxxx

# App — used for Stripe success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=https://insidestlcacademy.com
NEXT_PUBLIC_APP_URL=https://insidestlcacademy.com
